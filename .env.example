# LinkedIn Credentials
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# GitHub
GITHUB_USERNAME=your_github_username

# OpenAI API Key (optional - for AI-powered cover letter generation)
OPENAI_API_KEY=

# Default resume file path
DEFAULT_RESUME_PATH=./resume/resume.json

# Browser settings
HEADLESS=false
SLOW_MO=50

# Rate limiting (milliseconds between requests)
REQUEST_DELAY=2000
