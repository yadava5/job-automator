{
  "name": "job-automator",
  "version": "1.0.0",
  "description": "Daily new-grad job scout, source-backed resume pack generator, application tracker, and public dashboard publisher",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "job-automator": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "search": "node src/index.js search",
    "track": "node src/index.js track",
    "dashboard": "node src/index.js dashboard",
    "scout": "python3 scripts/generate_job_dashboard.py",
    "open-dashboard": "bash scripts/open_job_dashboard.sh",
    "publish-dashboard": "bash scripts/publish_dashboard_pages.sh",
    "audit-run": "python3 scripts/post_run_audit.py",
    "test:python": "${JOB_AUTOMATOR_PYTHON:-python3} -m unittest discover -s tests -v",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "job",
    "automation",
    "playwright",
    "linkedin",
    "indeed",
    "career"
  ],
  "author": "Ayush Yadav",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "inquirer": "^12.0.0",
    "marked": "^14.0.0",
    "playwright": "^1.48.0",
    "yaml": "^2.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
